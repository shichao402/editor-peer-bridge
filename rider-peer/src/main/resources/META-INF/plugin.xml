<idea-plugin>
    <id>com.editorpeerbridge.rider</id>
    <name>Editor Peer Bridge</name>
    <vendor email="shichao402@gmail.com" url="https://github.com/shichao402/editor-peer-bridge">shichao402</vendor>
    <description><![CDATA[Cross-editor code navigation tool. Jump between Rider, VSCode, Cursor, and CodeBuddy with a single keystroke.]]></description>

    <depends>com.intellij.modules.rider</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="com.editorpeerbridge.PeerBridgeService"/>
        <postStartupActivity implementation="com.editorpeerbridge.PeerStartupActivity"/>
        <notificationGroup id="Editor Peer Bridge" displayType="BALLOON" isLogByDefault="true"/>
    </extensions>

    <actions>
        <action id="EditorPeerBridge.JumpToPeer"
                class="com.editorpeerbridge.JumpToPeerAction"
                text="Editor Peer Bridge: Jump To Peer"
                description="Send current file and selection to a matching peer instance">
            <keyboard-shortcut first-keystroke="ctrl alt shift J" keymap="$default"/>
        </action>
    </actions>
</idea-plugin>
