{
  "name": "editor-peer-bridge-vscode-peer",
  "displayName": "Editor Peer Bridge",
  "description": "Local cross-editor jump bridge for Rider, VS Code, Cursor, and CodeBuddy.",
  "version": "0.0.9",
  "publisher": "shichao402",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shichao402/editor-peer-bridge"
  },
  "bugs": {
    "url": "https://github.com/shichao402/editor-peer-bridge/issues"
  },
  "homepage": "https://github.com/shichao402/editor-peer-bridge#readme",
  "keywords": [
    "jump",
    "navigation",
    "editor-bridge",
    "rider",
    "cursor",
    "codebuddy"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "assets/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:editorPeerBridge.jumpToPeer",
    "onCommand:editorPeerBridge.createConfig",
    "onCommand:editorPeerBridge.updateConfig",
    "onCommand:editorPeerBridge.openConfig"
  ],
  "contributes": {
    "commands": [
      {
        "command": "editorPeerBridge.jumpToPeer",
        "title": "Editor Peer Bridge: Jump To Peer"
      },
      {
        "command": "editorPeerBridge.createConfig",
        "title": "Editor Peer Bridge: Create Config"
      },
      {
        "command": "editorPeerBridge.updateConfig",
        "title": "Editor Peer Bridge: Update Config"
      },
      {
        "command": "editorPeerBridge.openConfig",
        "title": "Editor Peer Bridge: Open Config"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.6.3"
  }
}
